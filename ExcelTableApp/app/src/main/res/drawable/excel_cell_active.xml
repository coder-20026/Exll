<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- White background for active cell (like Excel) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/colorCellActive"/>
        </shape>
    </item>
    <!-- Thick green border for active cell (Excel-style) -->
    <item>
        <shape android:shape="rectangle">
            <stroke 
                android:width="2.5dp" 
                android:color="@color/colorCellActiveBorder"/>
            <solid android:color="@android:color/transparent"/>
        </shape>
    </item>
</layer-list>
