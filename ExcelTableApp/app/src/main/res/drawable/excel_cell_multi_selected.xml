<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Light blue/purple background for multi-cell selection (Excel-like) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/colorCellSelected"/>
        </shape>
    </item>
    <!-- Thin border (inner cells) -->
    <item>
        <shape android:shape="rectangle">
            <stroke 
                android:width="0.5dp" 
                android:color="@color/colorCellSelectedBorder"/>
            <solid android:color="@android:color/transparent"/>
        </shape>
    </item>
</layer-list>
