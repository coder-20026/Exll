<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/excelTableContainer"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Row 1: Header Row with Merged Cells - THICK BORDER -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="26dp"
        android:orientation="horizontal">
        
        <!-- A1-F1 Merged: FIELD EXECUTIVE NAME:- (THICK BORDER) -->
        <TextView
            android:id="@+id/cellA1F1"
            android:layout_width="340dp"
            android:layout_height="match_parent"
            android:text="FIELD EXECUTIVE NAME:-"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center_vertical|start"
            android:paddingStart="8dp"
            android:background="@drawable/excel_header_thick"/>
        
        <!-- G1-I1 Merged: DATE:- (THICK BORDER) -->
        <TextView
            android:id="@+id/cellG1I1"
            android:layout_width="177dp"
            android:layout_height="match_parent"
            android:text="DATE:-"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center_vertical|start"
            android:paddingStart="8dp"
            android:background="@drawable/excel_header_thick"/>
    </LinearLayout>

    <!-- Row 2: Column Headers - THICK BORDER -->
    <LinearLayout
        android:id="@+id/row2Headers"
        android:layout_width="wrap_content"
        android:layout_height="24dp"
        android:orientation="horizontal">
        
        <!-- A2: SR NO (THICK BORDER) -->
        <TextView
            android:layout_width="34dp"
            android:layout_height="match_parent"
            android:text="SR NO"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            android:background="@drawable/excel_header_thick"/>
        
        <!-- B2: BANK NAME (THICK BORDER) -->
        <TextView
            android:layout_width="62dp"
            android:layout_height="match_parent"
            android:text="BANK NAME"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            android:background="@drawable/excel_header_thick"/>
        
        <!-- C2: APPLICANT NAME (THICK BORDER) -->
        <TextView
            android:layout_width="169dp"
            android:layout_height="match_parent"
            android:text="APPLICANT NAME"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            android:background="@drawable/excel_header_thick"/>
        
        <!-- D2: STATUS (THICK BORDER) -->
        <TextView
            android:layout_width="30dp"
            android:layout_height="match_parent"
            android:text="STATUS"
            android:textSize="8sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            android:background="@drawable/excel_header_thick"/>
        
        <!-- E2: REASON FOR CNV (THICK BORDER) -->
        <TextView
            android:layout_width="42dp"
            android:layout_height="match_parent"
            android:text="REASON FOR CNV"
            android:textSize="6sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            android:maxLines="2"
            android:background="@drawable/excel_header_thick"/>
        
        <!-- F2: LAT-LONG FROM (THICK BORDER) -->
        <TextView
            android:layout_width="92dp"
            android:layout_height="match_parent"
            android:text="LAT-LONG FROM"
            android:textSize="8sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            android:background="@drawable/excel_header_thick"/>
        
        <!-- G2: LAT-LONG TO (THICK BORDER) -->
        <TextView
            android:layout_width="95dp"
            android:layout_height="match_parent"
            android:text="LAT-LONG TO"
            android:textSize="8sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            android:background="@drawable/excel_header_thick"/>
        
        <!-- H2: AREA (THICK BORDER) -->
        <TextView
            android:layout_width="89dp"
            android:layout_height="match_parent"
            android:text="AREA"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            android:background="@drawable/excel_header_thick"/>
        
        <!-- I2: KM (THICK BORDER) -->
        <TextView
            android:layout_width="38dp"
            android:layout_height="match_parent"
            android:text="KM"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            android:background="@drawable/excel_header_thick"/>
    </LinearLayout>

    <!-- Data Rows Container (Row 3-17) - will be populated programmatically with THIN BORDERS -->
    <LinearLayout
        android:id="@+id/dataRowsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"/>

    <!-- Additional Rows Container (Row 13-17) -->
    <LinearLayout
        android:id="@+id/additionalRowsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"/>

    <!-- Row 18: Blank Spacing Row -->
    <LinearLayout
        android:layout_width="517dp"
        android:layout_height="12dp"
        android:orientation="horizontal"
        android:background="@drawable/excel_data_thin"/>

    <!-- Bottom Summary Table (Row 19-24) -->
    <!-- Summary table ke liye wrapper with thick outer border -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">
        
        <!-- Left spacer -->
        <View
            android:layout_width="241dp"
            android:layout_height="match_parent"/>
        
        <!-- Summary Table with THICK OUTER BORDER (3dp) -->
        <LinearLayout
            android:id="@+id/summaryTableContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/excel_summary_outer">
            
            <!-- Row 19: Headers for Summary - THICK BORDER (2dp) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="22dp"
                android:orientation="horizontal">
                
                <!-- F19: Blank cell -->
                <TextView
                    android:layout_width="96dp"
                    android:layout_height="match_parent"
                    android:text=""
                    android:background="@drawable/excel_summary_header"/>
                
                <!-- G19: NO. OF COUNT -->
                <TextView
                    android:layout_width="99dp"
                    android:layout_height="match_parent"
                    android:text="NO. OF COUNT"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:gravity="center"
                    android:background="@drawable/excel_summary_header"/>
                
                <!-- H19: AMOUNT -->
                <TextView
                    android:layout_width="81dp"
                    android:layout_height="match_parent"
                    android:text="AMOUNT"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:gravity="center"
                    android:background="@drawable/excel_summary_header"/>
            </LinearLayout>
            
            <!-- Row 20: TOTAL KM - THIN BORDER (0.5dp) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="25dp"
                android:orientation="horizontal">
                
                <TextView
                    android:layout_width="96dp"
                    android:layout_height="match_parent"
                    android:text="TOTAL KM"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:gravity="center_vertical|start"
                    android:paddingStart="4dp"
                    android:background="@drawable/excel_summary_inner"/>
                
                <TextView
                    android:id="@+id/cellG20"
                    android:layout_width="99dp"
                    android:layout_height="match_parent"
                    android:text=""
                    android:textSize="9sp"
                    android:textColor="#000000"
                    android:gravity="center"
                    android:background="@drawable/excel_summary_inner"/>
                
                <TextView
                    android:id="@+id/cellH20"
                    android:layout_width="81dp"
                    android:layout_height="match_parent"
                    android:text=""
                    android:textSize="9sp"
                    android:textColor="#000000"
                    android:gravity="center"
                    android:background="@drawable/excel_summary_inner"/>
            </LinearLayout>
            
            <!-- Row 21: LUNCH - THIN BORDER -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="25dp"
                android:orientation="horizontal">
                
                <TextView
                    android:layout_width="96dp"
                    android:layout_height="match_parent"
                    android:text="LUNCH"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:gravity="center_vertical|start"
                    android:paddingStart="4dp"
                    android:background="@drawable/excel_summary_inner"/>
                
                <TextView
                    android:id="@+id/cellG21"
                    android:layout_width="99dp"
                    android:layout_height="match_parent"
                    android:text=""
                    android:textSize="9sp"
                    android:textColor="#000000"
                    android:gravity="center"
                    android:background="@drawable/excel_summary_inner"/>
                
                <TextView
                    android:id="@+id/cellH21"
                    android:layout_width="81dp"
                    android:layout_height="match_parent"
                    android:text=""
                    android:textSize="9sp"
                    android:textColor="#000000"
                    android:gravity="center"
                    android:background="@drawable/excel_summary_inner"/>
            </LinearLayout>
            
            <!-- Row 22: VISIT - THIN BORDER -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="25dp"
                android:orientation="horizontal">
                
                <TextView
                    android:layout_width="96dp"
                    android:layout_height="match_parent"
                    android:text="VISIT"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:gravity="center_vertical|start"
                    android:paddingStart="4dp"
                    android:background="@drawable/excel_summary_inner"/>
                
                <TextView
                    android:id="@+id/cellG22"
                    android:layout_width="99dp"
                    android:layout_height="match_parent"
                    android:text=""
                    android:textSize="9sp"
                    android:textColor="#000000"
                    android:gravity="center"
                    android:background="@drawable/excel_summary_inner"/>
                
                <TextView
                    android:id="@+id/cellH22"
                    android:layout_width="81dp"
                    android:layout_height="match_parent"
                    android:text=""
                    android:textSize="9sp"
                    android:textColor="#000000"
                    android:gravity="center"
                    android:background="@drawable/excel_summary_inner"/>
            </LinearLayout>
            
            <!-- Row 23: OTHER - THIN BORDER -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="25dp"
                android:orientation="horizontal">
                
                <TextView
                    android:layout_width="96dp"
                    android:layout_height="match_parent"
                    android:text="OTHER"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:gravity="center_vertical|start"
                    android:paddingStart="4dp"
                    android:background="@drawable/excel_summary_inner"/>
                
                <TextView
                    android:id="@+id/cellG23"
                    android:layout_width="99dp"
                    android:layout_height="match_parent"
                    android:text=""
                    android:textSize="9sp"
                    android:textColor="#000000"
                    android:gravity="center"
                    android:background="@drawable/excel_summary_inner"/>
                
                <TextView
                    android:id="@+id/cellH23"
                    android:layout_width="81dp"
                    android:layout_height="match_parent"
                    android:text=""
                    android:textSize="9sp"
                    android:textColor="#000000"
                    android:gravity="center"
                    android:background="@drawable/excel_summary_inner"/>
            </LinearLayout>
            
            <!-- Row 24: TOTAL AMOUNT - THICK BORDER (2dp) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="22dp"
                android:orientation="horizontal">
                
                <!-- F24+G24 Merged: TOTAL AMOUNT -->
                <TextView
                    android:layout_width="195dp"
                    android:layout_height="match_parent"
                    android:text="TOTAL AMOUNT"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:gravity="center"
                    android:background="@drawable/excel_summary_total"/>
                
                <TextView
                    android:id="@+id/cellH24"
                    android:layout_width="81dp"
                    android:layout_height="match_parent"
                    android:text=""
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:gravity="center"
                    android:background="@drawable/excel_summary_total"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
