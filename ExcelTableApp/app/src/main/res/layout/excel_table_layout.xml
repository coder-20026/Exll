<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/excelTableContainer"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Row 1: Header Row with Merged Cells -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="26dp"
        android:orientation="horizontal">
        
        <!-- A1-F1 Merged: FIELD EXECUTIVE NAME:- with thick border -->
        <TextView
            android:id="@+id/cellA1F1"
            android:layout_width="340dp"
            android:layout_height="match_parent"
            android:text="FIELD EXECUTIVE NAME:-   ALPESH CHAUHAN"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center_vertical|start"
            android:paddingStart="8dp"
            android:background="@drawable/excel_border_thick"/>
        
        <!-- G1-I1 Merged: DATE:- with thick border -->
        <TextView
            android:id="@+id/cellG1I1"
            android:layout_width="177dp"
            android:layout_height="match_parent"
            android:text="DATE:-"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center_vertical|start"
            android:paddingStart="8dp"
            android:background="@drawable/excel_border_thick"/>
    </LinearLayout>

    <!-- Row 2: Column Headers - All with THICK borders -->
    <LinearLayout
        android:id="@+id/row2Headers"
        android:layout_width="wrap_content"
        android:layout_height="24dp"
        android:orientation="horizontal">
        
        <!-- A2: SR NO -->
        <TextView
            android:layout_width="34dp"
            android:layout_height="match_parent"
            android:text="SR NO"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            android:background="@drawable/excel_border_thick"/>
        
        <!-- B2: BANK NAME -->
        <TextView
            android:layout_width="62dp"
            android:layout_height="match_parent"
            android:text="BANK NAME"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            android:background="@drawable/excel_border_thick"/>
        
        <!-- C2: APPLICANT NAME -->
        <TextView
            android:layout_width="169dp"
            android:layout_height="match_parent"
            android:text="APPLICANT NAME"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            android:background="@drawable/excel_border_thick"/>
        
        <!-- D2: STATUS -->
        <TextView
            android:layout_width="30dp"
            android:layout_height="match_parent"
            android:text="STATUS"
            android:textSize="8sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            android:background="@drawable/excel_border_thick"/>
        
        <!-- E2: REASON FOR CNV -->
        <TextView
            android:layout_width="42dp"
            android:layout_height="match_parent"
            android:text="REASON FOR CNV"
            android:textSize="6sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            android:maxLines="2"
            android:background="@drawable/excel_border_thick"/>
        
        <!-- F2: LAT-LONG FROM -->
        <TextView
            android:layout_width="92dp"
            android:layout_height="match_parent"
            android:text="LAT-LONG FROM"
            android:textSize="8sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            android:background="@drawable/excel_border_thick"/>
        
        <!-- G2: LAT-LONG TO -->
        <TextView
            android:layout_width="95dp"
            android:layout_height="match_parent"
            android:text="LAT-LONG TO"
            android:textSize="8sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            android:background="@drawable/excel_border_thick"/>
        
        <!-- H2: AREA -->
        <TextView
            android:layout_width="89dp"
            android:layout_height="match_parent"
            android:text="AREA"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            android:background="@drawable/excel_border_thick"/>
        
        <!-- I2: KM -->
        <TextView
            android:layout_width="38dp"
            android:layout_height="match_parent"
            android:text="KM"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            android:background="@drawable/excel_border_thick"/>
    </LinearLayout>

    <!-- Data Rows Container (Row 3-12) - will be populated programmatically -->
    <LinearLayout
        android:id="@+id/dataRowsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"/>

    <!-- Additional Rows Container (Row 13-17) -->
    <LinearLayout
        android:id="@+id/additionalRowsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"/>

    <!-- Row 18: Thick bottom line after 15 data rows -->
    <View
        android:layout_width="651dp"
        android:layout_height="3dp"
        android:background="#000000"/>
    
    <!-- Blank Spacing Row -->
    <LinearLayout
        android:layout_width="517dp"
        android:layout_height="8dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"/>

    <!-- Bottom Summary Table (Row 19-24) - With THICK outer border -->
    <LinearLayout
        android:id="@+id/summaryTableContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/excel_summary_outer"
        android:layout_marginStart="337dp">
        
        <!-- Row 19: Headers for Summary - THICK borders (Top Row) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="17dp"
            android:orientation="horizontal">
            
            <!-- F19: Blank - THICK -->
            <TextView
                android:layout_width="92dp"
                android:layout_height="match_parent"
                android:text=""
                android:background="@drawable/excel_border_thick"/>
            
            <!-- G19: NO. OF COUNT - THICK -->
            <TextView
                android:layout_width="95dp"
                android:layout_height="match_parent"
                android:text="NO. OF COUNT"
                android:textSize="8sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:gravity="center"
                android:background="@drawable/excel_border_thick"/>
            
            <!-- H19: AMOUNT - THICK -->
            <TextView
                android:layout_width="89dp"
                android:layout_height="match_parent"
                android:text="AMOUNT"
                android:textSize="8sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:gravity="center"
                android:background="@drawable/excel_border_thick"/>
        </LinearLayout>
        
        <!-- Row 20: TOTAL KM - THIN/MEDIUM borders (Inner Row) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="25dp"
            android:orientation="horizontal">
            
            <TextView
                android:layout_width="92dp"
                android:layout_height="match_parent"
                android:text="TOTAL KM"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:gravity="center"
                android:background="@drawable/excel_border_medium"/>
            
            <EditText
                android:id="@+id/cellTotalKmCount"
                android:layout_width="95dp"
                android:layout_height="match_parent"
                android:text=""
                android:textSize="9sp"
                android:textColor="#000000"
                android:gravity="center"
                android:inputType="number"
                android:background="@drawable/excel_border_medium"/>
            
            <EditText
                android:id="@+id/cellTotalKmAmount"
                android:layout_width="89dp"
                android:layout_height="match_parent"
                android:text=""
                android:textSize="9sp"
                android:textColor="#000000"
                android:gravity="center"
                android:inputType="numberDecimal"
                android:background="@drawable/excel_border_medium"/>
        </LinearLayout>
        
        <!-- Row 21: LUNCH - THIN/MEDIUM borders (Inner Row) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="25dp"
            android:orientation="horizontal">
            
            <TextView
                android:layout_width="92dp"
                android:layout_height="match_parent"
                android:text="LUNCH"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:gravity="center"
                android:background="@drawable/excel_border_medium"/>
            
            <EditText
                android:id="@+id/cellLunchCount"
                android:layout_width="95dp"
                android:layout_height="match_parent"
                android:text=""
                android:textSize="9sp"
                android:textColor="#000000"
                android:gravity="center"
                android:inputType="number"
                android:background="@drawable/excel_border_medium"/>
            
            <EditText
                android:id="@+id/cellLunchAmount"
                android:layout_width="89dp"
                android:layout_height="match_parent"
                android:text=""
                android:textSize="9sp"
                android:textColor="#000000"
                android:gravity="center"
                android:inputType="numberDecimal"
                android:background="@drawable/excel_border_medium"/>
        </LinearLayout>
        
        <!-- Row 22: VISIT - THIN/MEDIUM borders (Inner Row) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="25dp"
            android:orientation="horizontal">
            
            <TextView
                android:layout_width="92dp"
                android:layout_height="match_parent"
                android:text="VISIT"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:gravity="center"
                android:background="@drawable/excel_border_medium"/>
            
            <EditText
                android:id="@+id/cellVisitCount"
                android:layout_width="95dp"
                android:layout_height="match_parent"
                android:text=""
                android:textSize="9sp"
                android:textColor="#000000"
                android:gravity="center"
                android:inputType="number"
                android:background="@drawable/excel_border_medium"/>
            
            <EditText
                android:id="@+id/cellVisitAmount"
                android:layout_width="89dp"
                android:layout_height="match_parent"
                android:text=""
                android:textSize="9sp"
                android:textColor="#000000"
                android:gravity="center"
                android:inputType="numberDecimal"
                android:background="@drawable/excel_border_medium"/>
        </LinearLayout>
        
        <!-- Row 23: OTHER - THIN/MEDIUM borders (Inner Row) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:orientation="horizontal">
            
            <TextView
                android:layout_width="92dp"
                android:layout_height="match_parent"
                android:text="OTHER"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:gravity="center"
                android:background="@drawable/excel_border_medium"/>
            
            <EditText
                android:id="@+id/cellOtherCount"
                android:layout_width="95dp"
                android:layout_height="match_parent"
                android:text=""
                android:textSize="9sp"
                android:textColor="#000000"
                android:gravity="center"
                android:inputType="number"
                android:background="@drawable/excel_border_medium"/>
            
            <EditText
                android:id="@+id/cellOtherAmount"
                android:layout_width="89dp"
                android:layout_height="match_parent"
                android:text=""
                android:textSize="9sp"
                android:textColor="#000000"
                android:gravity="center"
                android:inputType="numberDecimal"
                android:background="@drawable/excel_border_medium"/>
        </LinearLayout>
        
        <!-- Row 24: TOTAL AMOUNT - THICK borders (Bottom Row) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="15dp"
            android:orientation="horizontal">
            
            <!-- F24+G24 Merged: TOTAL AMOUNT - THICK -->
            <TextView
                android:layout_width="187dp"
                android:layout_height="match_parent"
                android:text="TOTAL AMOUNT"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:gravity="center"
                android:background="@drawable/excel_border_thick"/>
            
            <!-- H24: Final Total Value - THICK -->
            <EditText
                android:id="@+id/cellFinalTotal"
                android:layout_width="89dp"
                android:layout_height="match_parent"
                android:text=""
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:gravity="center"
                android:inputType="numberDecimal"
                android:background="@drawable/excel_border_thick"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
