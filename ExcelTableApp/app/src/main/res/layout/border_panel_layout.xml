<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/borderPanelContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:elevation="4dp"
    android:visibility="gone">

    <!-- Border Panel Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:background="#E8EAF6">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Borders"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1A237E" />

        <TextView
            android:id="@+id/btnCloseBorderPanel"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:text="X"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FF5252"
            android:gravity="center"
            android:background="@drawable/close_btn_bg" />
    </LinearLayout>

    <!-- Border Options Grid - Row 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingVertical="8dp"
        android:paddingHorizontal="4dp">

        <!-- All Borders -->
        <LinearLayout
            android:id="@+id/btnBorderAll"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/border_option_bg"
            android:layout_margin="2dp"
            android:padding="4dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_border_all"
                android:scaleType="fitCenter" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All"
                android:textSize="8sp"
                android:textColor="#333333" />
        </LinearLayout>

        <!-- Inner Borders -->
        <LinearLayout
            android:id="@+id/btnBorderInner"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/border_option_bg"
            android:layout_margin="2dp"
            android:padding="4dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_border_inner"
                android:scaleType="fitCenter" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inner"
                android:textSize="8sp"
                android:textColor="#333333" />
        </LinearLayout>

        <!-- Outer Borders -->
        <LinearLayout
            android:id="@+id/btnBorderOuter"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/border_option_bg"
            android:layout_margin="2dp"
            android:padding="4dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_border_outer"
                android:scaleType="fitCenter" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Outer"
                android:textSize="8sp"
                android:textColor="#333333" />
        </LinearLayout>

        <!-- No Border / Clear -->
        <LinearLayout
            android:id="@+id/btnBorderNone"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/border_option_bg"
            android:layout_margin="2dp"
            android:padding="4dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_border_none"
                android:scaleType="fitCenter" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Clear"
                android:textSize="8sp"
                android:textColor="#FF5252" />
        </LinearLayout>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginHorizontal="8dp" />

    <!-- Border Options Grid - Row 2 (Individual Sides) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingVertical="8dp"
        android:paddingHorizontal="4dp">

        <!-- Top Border -->
        <LinearLayout
            android:id="@+id/btnBorderTop"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/border_option_bg"
            android:layout_margin="2dp"
            android:padding="4dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_border_top"
                android:scaleType="fitCenter" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Top"
                android:textSize="8sp"
                android:textColor="#333333" />
        </LinearLayout>

        <!-- Bottom Border -->
        <LinearLayout
            android:id="@+id/btnBorderBottom"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/border_option_bg"
            android:layout_margin="2dp"
            android:padding="4dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_border_bottom"
                android:scaleType="fitCenter" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bottom"
                android:textSize="8sp"
                android:textColor="#333333" />
        </LinearLayout>

        <!-- Left Border -->
        <LinearLayout
            android:id="@+id/btnBorderLeft"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/border_option_bg"
            android:layout_margin="2dp"
            android:padding="4dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_border_left"
                android:scaleType="fitCenter" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Left"
                android:textSize="8sp"
                android:textColor="#333333" />
        </LinearLayout>

        <!-- Right Border -->
        <LinearLayout
            android:id="@+id/btnBorderRight"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/border_option_bg"
            android:layout_margin="2dp"
            android:padding="4dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_border_right"
                android:scaleType="fitCenter" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Right"
                android:textSize="8sp"
                android:textColor="#333333" />
        </LinearLayout>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginHorizontal="8dp" />

    <!-- Border Options Grid - Row 3 (Inner Variations) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingVertical="8dp"
        android:paddingHorizontal="4dp">

        <!-- Horizontal Inner -->
        <LinearLayout
            android:id="@+id/btnBorderHorizontalInner"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/border_option_bg"
            android:layout_margin="2dp"
            android:padding="4dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_border_horizontal"
                android:scaleType="fitCenter" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="H-Inner"
                android:textSize="8sp"
                android:textColor="#333333" />
        </LinearLayout>

        <!-- Vertical Inner -->
        <LinearLayout
            android:id="@+id/btnBorderVerticalInner"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/border_option_bg"
            android:layout_margin="2dp"
            android:padding="4dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_border_vertical"
                android:scaleType="fitCenter" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="V-Inner"
                android:textSize="8sp"
                android:textColor="#333333" />
        </LinearLayout>

        <!-- Top + Bottom -->
        <LinearLayout
            android:id="@+id/btnBorderTopBottom"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/border_option_bg"
            android:layout_margin="2dp"
            android:padding="4dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_border_top_bottom"
                android:scaleType="fitCenter" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="T+B"
                android:textSize="8sp"
                android:textColor="#333333" />
        </LinearLayout>

        <!-- Placeholder for alignment -->
        <View
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_margin="2dp" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginHorizontal="8dp" />

    <!-- Border Options Grid - Row 4 (Thick/Double Variations) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingVertical="8dp"
        android:paddingHorizontal="4dp">

        <!-- Thick Bottom -->
        <LinearLayout
            android:id="@+id/btnBorderThickBottom"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/border_option_bg"
            android:layout_margin="2dp"
            android:padding="4dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_border_thick_bottom"
                android:scaleType="fitCenter" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thick B"
                android:textSize="8sp"
                android:textColor="#333333" />
        </LinearLayout>

        <!-- Double Bottom -->
        <LinearLayout
            android:id="@+id/btnBorderDoubleBottom"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/border_option_bg"
            android:layout_margin="2dp"
            android:padding="4dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_border_double_bottom"
                android:scaleType="fitCenter" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Double B"
                android:textSize="8sp"
                android:textColor="#333333" />
        </LinearLayout>

        <!-- Top + Thick Bottom -->
        <LinearLayout
            android:id="@+id/btnBorderTopThickBottom"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/border_option_bg"
            android:layout_margin="2dp"
            android:padding="4dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_border_top_thick_bottom"
                android:scaleType="fitCenter" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="T+ThickB"
                android:textSize="8sp"
                android:textColor="#333333" />
        </LinearLayout>

        <!-- Placeholder for alignment -->
        <View
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_margin="2dp" />

    </LinearLayout>

    <!-- Bottom padding -->
    <View
        android:layout_width="match_parent"
        android:layout_height="4dp" />

</LinearLayout>
