<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:maxHeight="450dp"
    android:orientation="vertical"
    android:background="@drawable/popup_bg"
    android:elevation="24dp">
    
    <!-- Premium Header with Gradient -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/popup_header_bg"
        android:padding="14dp">
        
        <!-- Header Content -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_centerVertical="true">
            
            <TextView
                android:id="@+id/tvPopupActiveRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Entry"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.02"/>
            
            <TextView
                android:id="@+id/tvPopupStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#E0FFFFFF"
                android:textSize="11sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
        
        <!-- Close Button - Premium Style -->
        <TextView
            android:id="@+id/btnClosePopup"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="&#10005;"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="@drawable/close_btn_bg"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:elevation="4dp"/>
    </RelativeLayout>
    
    <!-- Scrollable Content Area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="false"
        android:scrollbars="vertical"
        android:fadeScrollbars="false">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            
            <!-- Text Box 1 Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WhatsApp Text"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#1A237E"/>
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" (Auto from Clipboard)"
                    android:textSize="10sp"
                    android:textColor="#757575"/>
            </LinearLayout>
            
            <EditText
                android:id="@+id/etPopupText1"
                android:layout_width="match_parent"
                android:layout_height="75dp"
                android:hint="Auto-paste from clipboard..."
                android:textSize="12sp"
                android:textColor="#333333"
                android:textColorHint="#9E9E9E"
                android:padding="12dp"
                android:background="@drawable/input_bg"
                android:gravity="top|start"
                android:inputType="textMultiLine"
                android:scrollbars="vertical"
                android:layout_marginBottom="12dp"/>
            
            <!-- Live Preview Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Live Preview"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#1A237E"
                android:layout_marginBottom="6dp"/>
            
            <TextView
                android:id="@+id/tvPopupPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Waiting for data..."
                android:textSize="11sp"
                android:textColor="#5D4037"
                android:lineSpacingMultiplier="1.3"
                android:padding="12dp"
                android:background="@drawable/instruction_card_bg"
                android:minHeight="60dp"
                android:layout_marginBottom="12dp"/>
            
            <!-- Text Box 2 Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Coordinates"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#1A237E"/>
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" (Manual Entry)"
                    android:textSize="10sp"
                    android:textColor="#757575"/>
            </LinearLayout>
            
            <EditText
                android:id="@+id/etPopupText2"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="22.1704,71.6677"
                android:textSize="13sp"
                android:textColor="#333333"
                android:textColorHint="#9E9E9E"
                android:padding="12dp"
                android:background="@drawable/input_bg"
                android:inputType="text"
                android:layout_marginBottom="16dp"/>
            
            <!-- Action Buttons Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                
                <Button
                    android:id="@+id/btnPopupDone"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Save Entry"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    android:background="@drawable/btn_success_bg"
                    android:layout_marginEnd="4dp"
                    android:elevation="3dp"/>
                
                <Button
                    android:id="@+id/btnPopupClear"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Clear"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    android:background="@drawable/btn_warning_bg"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:elevation="3dp"/>
                
                <Button
                    android:id="@+id/btnOpenApp"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Open App"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    android:background="@drawable/btn_secondary_bg"
                    android:layout_marginStart="4dp"
                    android:elevation="3dp"/>
            </LinearLayout>
            
            <!-- Help Text -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tip: Long press floating button to close it"
                android:textSize="10sp"
                android:textColor="#9E9E9E"
                android:gravity="center"
                android:paddingTop="12dp"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
