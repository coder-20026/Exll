<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/livePreviewContainer"
    android:layout_width="210dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/popup_bg"
    android:elevation="16dp"
    android:padding="0dp">
    
    <!-- Compact Header - Draggable -->
    <LinearLayout
        android:id="@+id/livePreviewHeader"
        android:layout_width="match_parent"
        android:layout_height="26dp"
        android:orientation="horizontal"
        android:background="@drawable/popup_header_bg"
        android:paddingHorizontal="8dp"
        android:gravity="center_vertical">
        
        <TextView
            android:id="@+id/tvLivePreviewTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="LIVE PREVIEW"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"/>
        
        <TextView
            android:id="@+id/tvRowNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#E0FFFFFF"
            android:textSize="9sp"
            android:layout_marginEnd="6dp"/>
        
        <!-- Close Button -->
        <TextView
            android:id="@+id/btnCloseLivePreview"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:text="X"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="@drawable/close_btn_bg"/>
    </LinearLayout>
    
    <!-- Compact Content Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="6dp">
        
        <!-- Date Row (NEW) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp"
            android:background="@drawable/instruction_card_bg"
            android:padding="4dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DATE:"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#1A237E"
                android:layout_marginEnd="4dp"/>
            
            <EditText
                android:id="@+id/etLiveDate"
                android:layout_width="32dp"
                android:layout_height="22dp"
                android:hint="DD"
                android:textSize="10sp"
                android:textColor="#333333"
                android:textColorHint="#AAAAAA"
                android:paddingHorizontal="4dp"
                android:paddingVertical="0dp"
                android:background="@drawable/input_bg"
                android:inputType="number"
                android:maxLength="2"
                android:gravity="center"
                android:singleLine="true"/>
            
            <TextView
                android:id="@+id/tvDatePreview"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text=""
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#4CAF50"
                android:gravity="end"
                android:layout_marginStart="4dp"/>
        </LinearLayout>
        
        <!-- Bank Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="3dp">
            
            <TextView
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:text="BANK:"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#1A237E"/>
            
            <EditText
                android:id="@+id/etLiveBank"
                android:layout_width="0dp"
                android:layout_height="22dp"
                android:layout_weight="1"
                android:hint="-"
                android:textSize="9sp"
                android:textColor="#333333"
                android:textColorHint="#AAAAAA"
                android:paddingHorizontal="4dp"
                android:paddingVertical="0dp"
                android:background="@drawable/input_bg"
                android:inputType="text"
                android:singleLine="true"/>
        </LinearLayout>
        
        <!-- Name Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="3dp">
            
            <TextView
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:text="NAME:"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#1A237E"/>
            
            <EditText
                android:id="@+id/etLiveName"
                android:layout_width="0dp"
                android:layout_height="22dp"
                android:layout_weight="1"
                android:hint="-"
                android:textSize="9sp"
                android:textColor="#333333"
                android:textColorHint="#AAAAAA"
                android:paddingHorizontal="4dp"
                android:paddingVertical="0dp"
                android:background="@drawable/input_bg"
                android:inputType="text"
                android:singleLine="true"/>
        </LinearLayout>
        
        <!-- Reason Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="3dp">
            
            <TextView
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:text="REASON:"
                android:textSize="8sp"
                android:textStyle="bold"
                android:textColor="#1A237E"/>
            
            <EditText
                android:id="@+id/etLiveReason"
                android:layout_width="0dp"
                android:layout_height="22dp"
                android:layout_weight="1"
                android:hint="-"
                android:textSize="9sp"
                android:textColor="#333333"
                android:textColorHint="#AAAAAA"
                android:paddingHorizontal="4dp"
                android:paddingVertical="0dp"
                android:background="@drawable/input_bg"
                android:inputType="text"
                android:singleLine="true"/>
        </LinearLayout>
        
        <!-- Coords Row (LATLONG TO) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="3dp">
            
            <TextView
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:text="COORDS:"
                android:textSize="8sp"
                android:textStyle="bold"
                android:textColor="#1A237E"/>
            
            <EditText
                android:id="@+id/etLiveCoords"
                android:layout_width="0dp"
                android:layout_height="22dp"
                android:layout_weight="1"
                android:hint="22.12,71.12"
                android:textSize="9sp"
                android:textColor="#333333"
                android:textColorHint="#AAAAAA"
                android:paddingHorizontal="4dp"
                android:paddingVertical="0dp"
                android:background="@drawable/input_bg"
                android:inputType="text"
                android:singleLine="true"/>
        </LinearLayout>
        
        <!-- Area Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="5dp">
            
            <TextView
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:text="AREA:"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#1A237E"/>
            
            <EditText
                android:id="@+id/etLiveArea"
                android:layout_width="0dp"
                android:layout_height="22dp"
                android:layout_weight="1"
                android:hint="City"
                android:textSize="9sp"
                android:textColor="#333333"
                android:textColorHint="#AAAAAA"
                android:paddingHorizontal="4dp"
                android:paddingVertical="0dp"
                android:background="@drawable/input_bg"
                android:inputType="text"
                android:singleLine="true"/>
        </LinearLayout>
        
        <!-- Action Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            
            <Button
                android:id="@+id/btnLiveOk"
                android:layout_width="0dp"
                android:layout_height="26dp"
                android:layout_weight="1"
                android:text="OK"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:textAllCaps="true"
                android:background="@drawable/btn_success_bg"
                android:layout_marginEnd="3dp"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="0dp"/>
            
            <Button
                android:id="@+id/btnLiveClear"
                android:layout_width="0dp"
                android:layout_height="26dp"
                android:layout_weight="1"
                android:text="CLEAR"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:textAllCaps="true"
                android:background="@drawable/btn_warning_bg"
                android:layout_marginStart="3dp"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="0dp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
