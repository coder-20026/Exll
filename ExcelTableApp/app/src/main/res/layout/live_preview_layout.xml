<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/livePreviewContainer"
    android:layout_width="200dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/popup_bg"
    android:elevation="16dp"
    android:padding="0dp">
    
    <!-- Compact Header - Draggable -->
    <LinearLayout
        android:id="@+id/livePreviewHeader"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:orientation="horizontal"
        android:background="@drawable/popup_header_bg"
        android:paddingHorizontal="8dp"
        android:gravity="center_vertical">
        
        <TextView
            android:id="@+id/tvLivePreviewTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Live Preview"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"/>
        
        <TextView
            android:id="@+id/tvRowNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#E0FFFFFF"
            android:textSize="9sp"
            android:layout_marginEnd="6dp"/>
        
        <!-- Close Button -->
        <TextView
            android:id="@+id/btnCloseLivePreview"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:text="X"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="@drawable/close_btn_bg"/>
    </LinearLayout>
    
    <!-- Compact Content Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="6dp">
        
        <!-- Bank Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="3dp">
            
            <TextView
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:text="Bank:"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#1A237E"/>
            
            <EditText
                android:id="@+id/etLiveBank"
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_weight="1"
                android:hint="-"
                android:textSize="9sp"
                android:textColor="#333333"
                android:textColorHint="#AAAAAA"
                android:paddingHorizontal="4dp"
                android:paddingVertical="2dp"
                android:background="@drawable/input_bg"
                android:inputType="text"
                android:singleLine="true"/>
        </LinearLayout>
        
        <!-- Name Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="3dp">
            
            <TextView
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:text="Name:"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#1A237E"/>
            
            <EditText
                android:id="@+id/etLiveName"
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_weight="1"
                android:hint="-"
                android:textSize="9sp"
                android:textColor="#333333"
                android:textColorHint="#AAAAAA"
                android:paddingHorizontal="4dp"
                android:paddingVertical="2dp"
                android:background="@drawable/input_bg"
                android:inputType="text"
                android:singleLine="true"/>
        </LinearLayout>
        
        <!-- Reason Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="3dp">
            
            <TextView
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:text="Reason:"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#1A237E"/>
            
            <EditText
                android:id="@+id/etLiveReason"
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_weight="1"
                android:hint="-"
                android:textSize="9sp"
                android:textColor="#333333"
                android:textColorHint="#AAAAAA"
                android:paddingHorizontal="4dp"
                android:paddingVertical="2dp"
                android:background="@drawable/input_bg"
                android:inputType="text"
                android:singleLine="true"/>
        </LinearLayout>
        
        <!-- Coords Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="3dp">
            
            <TextView
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:text="Coords:"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#1A237E"/>
            
            <EditText
                android:id="@+id/etLiveCoords"
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_weight="1"
                android:hint="22.12,71.12"
                android:textSize="9sp"
                android:textColor="#333333"
                android:textColorHint="#AAAAAA"
                android:paddingHorizontal="4dp"
                android:paddingVertical="2dp"
                android:background="@drawable/input_bg"
                android:inputType="text"
                android:singleLine="true"/>
        </LinearLayout>
        
        <!-- Area Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">
            
            <TextView
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:text="Area:"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#1A237E"/>
            
            <EditText
                android:id="@+id/etLiveArea"
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_weight="1"
                android:hint="City"
                android:textSize="9sp"
                android:textColor="#333333"
                android:textColorHint="#AAAAAA"
                android:paddingHorizontal="4dp"
                android:paddingVertical="2dp"
                android:background="@drawable/input_bg"
                android:inputType="text"
                android:singleLine="true"/>
        </LinearLayout>
        
        <!-- Action Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            
            <Button
                android:id="@+id/btnLiveOk"
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:text="OK"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:background="@drawable/btn_success_bg"
                android:layout_marginEnd="3dp"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="0dp"/>
            
            <Button
                android:id="@+id/btnLiveClear"
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:text="Clear"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:background="@drawable/btn_warning_bg"
                android:layout_marginStart="3dp"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="0dp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
