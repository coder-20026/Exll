<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/app_gradient_bg">
    
    <!-- Premium Header Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/table_header_bg"
        android:padding="12dp"
        android:elevation="8dp">
        
        <!-- Top Row: Title + Enable Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="WHTSTABLE MASTER"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.05"/>
            
            <!-- Enable Bubble Toggle Button (Circular) -->
            <Button
                android:id="@+id/btnToggleFloating"
                android:layout_width="100dp"
                android:layout_height="36dp"
                android:text="ENABLE"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:background="@drawable/btn_success_bg"
                android:elevation="4dp"/>
        </LinearLayout>
        
        <!-- Month/Year Selection Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MONTH:"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#B3FFFFFF"
                android:layout_marginEnd="6dp"/>
            
            <Button
                android:id="@+id/btnSelectMonth"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:minWidth="80dp"
                android:text="January"
                android:textColor="#1A237E"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:background="@drawable/card_bg"
                android:paddingHorizontal="12dp"
                android:layout_marginEnd="12dp"/>
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YEAR:"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#B3FFFFFF"
                android:layout_marginEnd="6dp"/>
            
            <Button
                android:id="@+id/btnSelectYear"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:minWidth="60dp"
                android:text="2026"
                android:textColor="#1A237E"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:background="@drawable/card_bg"
                android:paddingHorizontal="12dp"
                android:layout_marginEnd="12dp"/>
            
            <!-- History Button -->
            <Button
                android:id="@+id/btnHistory"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="HISTORY"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:background="@drawable/btn_secondary_bg"
                android:paddingHorizontal="12dp"/>
        </LinearLayout>
    </LinearLayout>
    
    <!-- Main Content Area - Table Only -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="8dp">
        
        <!-- Current Date Display -->
        <LinearLayout
            android:id="@+id/currentDateContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/instruction_card_bg"
            android:padding="8dp"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CURRENT DATE:"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#1A237E"
                android:layout_marginEnd="8dp"/>
            
            <TextView
                android:id="@+id/tvCurrentDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#4CAF50"/>
            
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>
            
            <TextView
                android:id="@+id/tvEntryCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 Entries"
                android:textSize="11sp"
                android:textColor="#757575"/>
        </LinearLayout>
        
        <!-- Scrollable Table Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/shadow_bg"
            android:padding="2dp">
            
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="false"
                android:scrollbars="horizontal"
                android:fadeScrollbars="false">
                
                <ScrollView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:fillViewport="false"
                    android:scrollbars="vertical"
                    android:fadeScrollbars="false">
                    
                    <TableLayout
                        android:id="@+id/tableLayout"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#FFFFFF"
                        android:stretchColumns="*"/>
                    
                </ScrollView>
            </HorizontalScrollView>
        </LinearLayout>
    </LinearLayout>
    
    <!-- Bottom Action Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1A237E"
        android:padding="8dp"
        android:gravity="center">
        
        <Button
            android:id="@+id/btnCopyAll"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="COPY ALL"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:background="@drawable/btn_primary_bg"
            android:layout_marginEnd="4dp"/>
        
        <Button
            android:id="@+id/btnClearTable"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="CLEAR TABLE"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:background="@drawable/btn_danger_bg"
            android:layout_marginStart="4dp"/>
    </LinearLayout>
    
</LinearLayout>
