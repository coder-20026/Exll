<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Top Action Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:background="#E8EAF6">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="WhtsTable Master"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#1A237E" />

        <Button
            android:id="@+id/btnSelectMonth"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:minWidth="60dp"
            android:text="Jan"
            android:textSize="10sp"
            android:background="@drawable/btn_secondary_bg"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="8dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnSelectYear"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:minWidth="50dp"
            android:text="2026"
            android:textSize="10sp"
            android:background="@drawable/btn_secondary_bg"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="8dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnHistory"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:text="History"
            android:textSize="10sp"
            android:background="@drawable/btn_warning_bg"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="10dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnToggleFloating"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:text="Enable"
            android:textSize="10sp"
            android:background="@drawable/btn_success_bg"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="10dp" />
    </LinearLayout>

    <!-- Current Date Display -->
    <LinearLayout
        android:id="@+id/currentDateContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:gravity="center_vertical"
        android:background="#F5F5F5">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DATE: "
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#333333" />

        <TextView
            android:id="@+id/tvCurrentDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#4CAF50" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tvEntryCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 Entries"
            android:textSize="10sp"
            android:textColor="#666666" />
    </LinearLayout>

    <!-- Main Excel Table - Scrollable Both Directions -->
    <HorizontalScrollView
        android:id="@+id/horizontalScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="horizontal">

        <ScrollView
            android:id="@+id/verticalScroll"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="4dp">

                <!-- ========== OUTER THICK BORDER - Contains Both Tables ========== -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/excel_border_thick"
                    android:padding="2dp">

                <!-- ========== MAIN TABLE ========== -->
                <LinearLayout
                    android:id="@+id/excelTableContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- ============ ROW 1: Header Row (Merged Cells) ============ -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- A1-F1: FIELD EXECUTIVE NAME (Merged 6 columns: A to F) -->
                        <!-- Width = 34+62+200+30+45+92 = 463dp -->
                        <EditText
                            android:id="@+id/cellA1F1"
                            android:layout_width="463dp"
                            android:layout_height="28dp"
                            android:background="@drawable/excel_border_thin"
                            android:gravity="center_vertical"
                            android:paddingStart="6dp"
                            android:text="FIELD EXECUTIVE NAME:-"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#000000"
                            android:inputType="text"
                            android:singleLine="true" />

                        <!-- G1-I1: DATE (Merged 3 columns: G to I) -->
                        <!-- Width = 95+89+38 = 222dp -->
                        <EditText
                            android:id="@+id/cellG1I1"
                            android:layout_width="222dp"
                            android:layout_height="28dp"
                            android:background="@drawable/excel_border_thin"
                            android:gravity="center_vertical"
                            android:paddingStart="6dp"
                            android:text="DATE:-"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#000000"
                            android:inputType="text"
                            android:singleLine="true" />

                    </LinearLayout>

                    <!-- ============ ROW 2: Column Headers - Single Line, Same Height (24dp) ============ -->
                    <LinearLayout
                        android:id="@+id/row2Headers"
                        android:layout_width="wrap_content"
                        android:layout_height="24dp"
                        android:orientation="horizontal"
                        android:baselineAligned="false">

                        <!-- A2: SR NO - Width 34dp (6.71 ratio) -->
                        <TextView
                            android:layout_width="34dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/excel_header_cell"
                            android:gravity="center"
                            android:text="SR NO"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#000000"
                            android:maxLines="1" />

                        <!-- B2: BANK NAME - Width 62dp (12.43 ratio) -->
                        <TextView
                            android:layout_width="62dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/excel_header_cell"
                            android:gravity="center"
                            android:text="BANK NAME"
                            android:textSize="8sp"
                            android:textStyle="bold"
                            android:textColor="#000000"
                            android:maxLines="1" />

                        <!-- C2: APPLICANT NAME - Width 200dp (40.0 ratio) -->
                        <TextView
                            android:layout_width="200dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/excel_header_cell"
                            android:gravity="center"
                            android:text="APPLICANT NAME"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#000000"
                            android:maxLines="1" />

                        <!-- D2: STATUS - Width 30dp (5.86 ratio) -->
                        <TextView
                            android:layout_width="30dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/excel_header_cell"
                            android:gravity="center"
                            android:text="STATUS"
                            android:textSize="6sp"
                            android:textStyle="bold"
                            android:textColor="#000000"
                            android:maxLines="1" />

                        <!-- E2: REASON FOR CNV - Width 45dp (8.43 ratio) -->
                        <TextView
                            android:layout_width="45dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/excel_header_cell"
                            android:gravity="center"
                            android:text="REASON"
                            android:textSize="7sp"
                            android:textStyle="bold"
                            android:textColor="#000000"
                            android:maxLines="1" />

                        <!-- F2: LATLONG FROM - Width 92dp (18.43 ratio) -->
                        <TextView
                            android:layout_width="92dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/excel_header_cell"
                            android:gravity="center"
                            android:text="LATLONG FROM"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:textColor="#000000"
                            android:maxLines="1" />

                        <!-- G2: LATLONG TO - Width 95dp (19.0 ratio) -->
                        <TextView
                            android:layout_width="95dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/excel_header_cell"
                            android:gravity="center"
                            android:text="LATLONG TO"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#000000"
                            android:maxLines="1" />

                        <!-- H2: AREA - Width 89dp (17.86 ratio) -->
                        <TextView
                            android:layout_width="89dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/excel_header_cell"
                            android:gravity="center"
                            android:text="AREA"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#000000"
                            android:maxLines="1" />

                        <!-- I2: KM - Width 38dp (7.57 ratio) -->
                        <TextView
                            android:layout_width="38dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/excel_header_cell"
                            android:gravity="center"
                            android:text="KM"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#000000"
                            android:maxLines="1" />

                    </LinearLayout>

                    <!-- ============ DATA ROWS CONTAINER (Row 3-17 = 15 rows) ============ -->
                    <LinearLayout
                        android:id="@+id/dataRowsContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <!-- Data rows will be added programmatically -->
                    </LinearLayout>

                </LinearLayout>

                <!-- Gap between main table and summary table (10dp) -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="10dp" />

                <!-- ========== BOTTOM SUMMARY TABLE ========== -->
                <LinearLayout
                    android:id="@+id/summaryTableContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_gravity="end"
                    android:layout_marginEnd="38dp">

                    <!-- Summary Row 1: Header - Fixed 24dp height, same for all cells -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="24dp"
                        android:orientation="horizontal"
                        android:baselineAligned="false">

                        <!-- F19: Blank -->
                        <TextView
                            android:layout_width="92dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/excel_border_thin"
                            android:gravity="center"
                            android:text=""
                            android:textSize="11sp"
                            android:textColor="#000000" />

                        <!-- G19: NO. OF COUNT -->
                        <TextView
                            android:layout_width="95dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/excel_border_thin"
                            android:gravity="center"
                            android:text="NO. OF COUNT"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:textColor="#000000" />

                        <!-- H19: AMOUNT -->
                        <TextView
                            android:layout_width="89dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/excel_border_thin"
                            android:gravity="center"
                            android:text="AMOUNT"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#000000" />

                    </LinearLayout>

                    <!-- Summary Row 2: TOTAL KM - Fixed 26dp height -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="26dp"
                        android:orientation="horizontal"
                        android:baselineAligned="false">

                        <TextView
                            android:layout_width="92dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/excel_border_thin"
                            android:gravity="center_vertical|start"
                            android:paddingStart="4dp"
                            android:text="TOTAL KM"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#000000" />

                        <EditText
                            android:id="@+id/cellTotalKmCount"
                            android:layout_width="95dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/excel_border_thin"
                            android:gravity="center"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:inputType="numberDecimal"
                            android:textColor="#000000"
                            android:padding="0dp" />

                        <EditText
                            android:id="@+id/cellTotalKmAmount"
                            android:layout_width="89dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/excel_border_thin"
                            android:gravity="center"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:inputType="numberDecimal"
                            android:textColor="#000000"
                            android:padding="0dp" />

                    </LinearLayout>

                    <!-- Summary Row 3: LUNCH - Fixed 26dp height -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="26dp"
                        android:orientation="horizontal"
                        android:baselineAligned="false">

                        <TextView
                            android:layout_width="92dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/excel_border_thin"
                            android:gravity="center_vertical|start"
                            android:paddingStart="4dp"
                            android:text="LUNCH"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#000000" />

                        <EditText
                            android:id="@+id/cellLunchCount"
                            android:layout_width="95dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/excel_border_thin"
                            android:gravity="center"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:inputType="numberDecimal"
                            android:textColor="#000000"
                            android:padding="0dp" />

                        <EditText
                            android:id="@+id/cellLunchAmount"
                            android:layout_width="89dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/excel_border_thin"
                            android:gravity="center"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:inputType="numberDecimal"
                            android:textColor="#000000"
                            android:padding="0dp" />

                    </LinearLayout>

                    <!-- Summary Row 4: VISIT - Fixed 26dp height -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="26dp"
                        android:orientation="horizontal"
                        android:baselineAligned="false">

                        <TextView
                            android:layout_width="92dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/excel_border_thin"
                            android:gravity="center_vertical|start"
                            android:paddingStart="4dp"
                            android:text="VISIT"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#000000" />

                        <EditText
                            android:id="@+id/cellVisitCount"
                            android:layout_width="95dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/excel_border_thin"
                            android:gravity="center"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:inputType="numberDecimal"
                            android:textColor="#000000"
                            android:padding="0dp" />

                        <EditText
                            android:id="@+id/cellVisitAmount"
                            android:layout_width="89dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/excel_border_thin"
                            android:gravity="center"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:inputType="numberDecimal"
                            android:textColor="#000000"
                            android:padding="0dp" />

                    </LinearLayout>

                    <!-- Summary Row 5: OTHER - Fixed 26dp height -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="26dp"
                        android:orientation="horizontal"
                        android:baselineAligned="false">

                        <TextView
                            android:layout_width="92dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/excel_border_thin"
                            android:gravity="center_vertical|start"
                            android:paddingStart="4dp"
                            android:text="OTHER"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#000000" />

                        <EditText
                            android:id="@+id/cellOtherCount"
                            android:layout_width="95dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/excel_border_thin"
                            android:gravity="center"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:inputType="numberDecimal"
                            android:textColor="#000000"
                            android:padding="0dp" />

                        <EditText
                            android:id="@+id/cellOtherAmount"
                            android:layout_width="89dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/excel_border_thin"
                            android:gravity="center"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:inputType="numberDecimal"
                            android:textColor="#000000"
                            android:padding="0dp" />

                    </LinearLayout>

                    <!-- Summary Row 6: TOTAL AMOUNT - Fixed 24dp height -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="24dp"
                        android:orientation="horizontal"
                        android:baselineAligned="false">

                        <!-- F24+G24 Merged: TOTAL AMOUNT label (92+95=187dp) -->
                        <TextView
                            android:layout_width="187dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/excel_border_thin"
                            android:gravity="center"
                            android:text="TOTAL AMOUNT"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#000000" />

                        <!-- H24: Final Total Value -->
                        <EditText
                            android:id="@+id/cellFinalTotal"
                            android:layout_width="89dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/excel_border_thin"
                            android:gravity="center"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:inputType="numberDecimal"
                            android:textColor="#000000"
                            android:padding="0dp" />

                    </LinearLayout>

                </LinearLayout>

                </LinearLayout>

                <!-- Bottom padding -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="16dp" />

            </LinearLayout>

        </ScrollView>

    </HorizontalScrollView>

</LinearLayout>
