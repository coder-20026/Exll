<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/app_gradient_bg">
    
    <!-- Premium Header Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/table_header_bg"
        android:padding="16dp"
        android:elevation="8dp">
        
        <!-- App Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="WhatsApp Table Master"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:letterSpacing="0.05"/>
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Premium Data Entry Tool"
            android:textSize="12sp"
            android:textColor="#B3FFFFFF"
            android:gravity="center"
            android:layout_marginTop="2dp"/>
    </LinearLayout>
    
    <!-- Main Content Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="12dp">
        
        <!-- Floating Button Toggle - Premium Style -->
        <Button
            android:id="@+id/btnToggleFloating"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Enable Quick Entry Mode"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:background="@drawable/btn_success_bg"
            android:layout_marginBottom="12dp"
            android:elevation="4dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"/>
        
        <!-- Input Section Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/shadow_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp">
            
            <!-- Text Box 1 Label -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WhatsApp Text"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#1A237E"/>
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" (Required)"
                    android:textSize="11sp"
                    android:textColor="#FF5252"/>
            </LinearLayout>
            
            <EditText
                android:id="@+id/textBox1"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:hint="Paste WhatsApp text here..."
                android:gravity="top|start"
                android:padding="12dp"
                android:background="@drawable/input_bg"
                android:textSize="13sp"
                android:textColor="#333333"
                android:textColorHint="#9E9E9E"
                android:inputType="textMultiLine"
                android:scrollbars="vertical"
                android:layout_marginBottom="12dp"/>
            
            <!-- Text Box 2 Label -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OCR / Location Text"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#1A237E"/>
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" (Optional)"
                    android:textSize="11sp"
                    android:textColor="#757575"/>
            </LinearLayout>
            
            <EditText
                android:id="@+id/textBox2"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:hint="Paste coordinates or OCR text..."
                android:gravity="top|start"
                android:padding="12dp"
                android:background="@drawable/input_bg"
                android:textSize="13sp"
                android:textColor="#333333"
                android:textColorHint="#9E9E9E"
                android:inputType="textMultiLine"
                android:scrollbars="vertical"/>
        </LinearLayout>
        
        <!-- Action Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            
            <Button
                android:id="@+id/btnParse"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Parse &amp; Fill"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:background="@drawable/btn_primary_bg"
                android:layout_marginEnd="6dp"
                android:elevation="3dp"/>
            
            <Button
                android:id="@+id/btnCopyAll"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Copy All"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:background="@drawable/btn_secondary_bg"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:elevation="3dp"/>
            
            <Button
                android:id="@+id/btnClear"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Clear"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:background="@drawable/btn_danger_bg"
                android:layout_marginStart="6dp"
                android:elevation="3dp"/>
        </LinearLayout>
        
        <!-- Instructions Card -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Paste text &#8594; Parse &#8594; Long-press row for options &#8594; Copy All for Excel"
            android:textSize="11sp"
            android:textColor="#5D4037"
            android:padding="12dp"
            android:background="@drawable/instruction_card_bg"
            android:layout_marginBottom="12dp"
            android:gravity="center"/>
        
        <!-- Scrollable Table Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/shadow_bg"
            android:padding="2dp">
            
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="false"
                android:scrollbars="horizontal"
                android:fadeScrollbars="false">
                
                <ScrollView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:fillViewport="false"
                    android:scrollbars="vertical"
                    android:fadeScrollbars="false">
                    
                    <TableLayout
                        android:id="@+id/tableLayout"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#FFFFFF"
                        android:stretchColumns="*"/>
                    
                </ScrollView>
            </HorizontalScrollView>
        </LinearLayout>
    </LinearLayout>
    
    <!-- Bottom Status Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1A237E"
        android:padding="8dp"
        android:gravity="center">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WhtsTable Master v2.0"
            android:textSize="11sp"
            android:textColor="#B3FFFFFF"/>
    </LinearLayout>
    
</LinearLayout>
