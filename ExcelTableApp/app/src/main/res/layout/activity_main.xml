<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/app_gradient_bg">
    
    <!-- Premium Header Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/table_header_bg"
        android:padding="12dp"
        android:elevation="8dp">
        
        <!-- Top Row: Title + Enable Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="WHTSTABLE MASTER"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.05"/>
            
            <!-- Enable Bubble Toggle Button (Circular) -->
            <Button
                android:id="@+id/btnToggleFloating"
                android:layout_width="100dp"
                android:layout_height="36dp"
                android:text="ENABLE"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:background="@drawable/btn_success_bg"
                android:elevation="4dp"/>
        </LinearLayout>
        
        <!-- Month/Year Selection Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MONTH:"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#B3FFFFFF"
                android:layout_marginEnd="6dp"/>
            
            <Button
                android:id="@+id/btnSelectMonth"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:minWidth="80dp"
                android:text="January"
                android:textColor="#1A237E"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:background="@drawable/card_bg"
                android:paddingHorizontal="12dp"
                android:layout_marginEnd="12dp"/>
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YEAR:"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#B3FFFFFF"
                android:layout_marginEnd="6dp"/>
            
            <Button
                android:id="@+id/btnSelectYear"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:minWidth="60dp"
                android:text="2026"
                android:textColor="#1A237E"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:background="@drawable/card_bg"
                android:paddingHorizontal="12dp"
                android:layout_marginEnd="12dp"/>
            
            <!-- History Button -->
            <Button
                android:id="@+id/btnHistory"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="HISTORY"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:background="@drawable/btn_secondary_bg"
                android:paddingHorizontal="12dp"/>
        </LinearLayout>
    </LinearLayout>
    
    <!-- Main Content Area - Excel Table -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="8dp">
        
        <!-- Current Date Display -->
        <LinearLayout
            android:id="@+id/currentDateContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/instruction_card_bg"
            android:padding="8dp"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CURRENT DATE:"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#1A237E"
                android:layout_marginEnd="8dp"/>
            
            <TextView
                android:id="@+id/tvCurrentDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#4CAF50"/>
            
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>
            
            <TextView
                android:id="@+id/tvEntryCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 Entries"
                android:textSize="11sp"
                android:textColor="#757575"/>
        </LinearLayout>
        
        <!-- Scrollable Excel Table Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/shadow_bg"
            android:padding="2dp">
            
            <HorizontalScrollView
                android:id="@+id/horizontalScroll"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="false"
                android:scrollbars="horizontal"
                android:fadeScrollbars="false">
                
                <ScrollView
                    android:id="@+id/verticalScroll"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:fillViewport="false"
                    android:scrollbars="vertical"
                    android:fadeScrollbars="false">
                    
                    <!-- Excel Table Structure -->
                    <LinearLayout
                        android:id="@+id/excelTableContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="#FFFFFF">

                        <!-- Row 1: Header Row with Merged Cells -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="26dp"
                            android:orientation="horizontal">
                            
                            <!-- A1-F1 Merged: FIELD EXECUTIVE NAME:- -->
                            <EditText
                                android:id="@+id/cellA1F1"
                                android:layout_width="340dp"
                                android:layout_height="match_parent"
                                android:text="FIELD EXECUTIVE NAME:-"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="#000000"
                                android:gravity="center_vertical|start"
                                android:paddingStart="8dp"
                                android:paddingEnd="4dp"
                                android:background="@drawable/excel_cell_border"
                                android:inputType="text"
                                android:singleLine="true"/>
                            
                            <!-- G1-I1 Merged: DATE:- -->
                            <EditText
                                android:id="@+id/cellG1I1"
                                android:layout_width="177dp"
                                android:layout_height="match_parent"
                                android:text="DATE:-"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="#000000"
                                android:gravity="center_vertical|start"
                                android:paddingStart="8dp"
                                android:paddingEnd="4dp"
                                android:background="@drawable/excel_cell_border"
                                android:inputType="text"
                                android:singleLine="true"/>
                        </LinearLayout>

                        <!-- Row 2: Column Headers -->
                        <LinearLayout
                            android:id="@+id/row2Headers"
                            android:layout_width="wrap_content"
                            android:layout_height="24dp"
                            android:orientation="horizontal">
                            
                            <!-- A2: SR NO -->
                            <TextView
                                android:layout_width="34dp"
                                android:layout_height="match_parent"
                                android:text="SR NO"
                                android:textSize="8sp"
                                android:textStyle="bold"
                                android:textColor="#000000"
                                android:gravity="center"
                                android:background="@drawable/excel_cell_border"/>
                            
                            <!-- B2: BANK NAME -->
                            <TextView
                                android:layout_width="62dp"
                                android:layout_height="match_parent"
                                android:text="BANK NAME"
                                android:textSize="7sp"
                                android:textStyle="bold"
                                android:textColor="#000000"
                                android:gravity="center"
                                android:background="@drawable/excel_cell_border"/>
                            
                            <!-- C2: APPLICANT NAME -->
                            <TextView
                                android:layout_width="169dp"
                                android:layout_height="match_parent"
                                android:text="APPLICANT NAME"
                                android:textSize="8sp"
                                android:textStyle="bold"
                                android:textColor="#000000"
                                android:gravity="center"
                                android:background="@drawable/excel_cell_border"/>
                            
                            <!-- D2: STATUS -->
                            <TextView
                                android:layout_width="30dp"
                                android:layout_height="match_parent"
                                android:text="STATUS"
                                android:textSize="6sp"
                                android:textStyle="bold"
                                android:textColor="#000000"
                                android:gravity="center"
                                android:background="@drawable/excel_cell_border"/>
                            
                            <!-- E2: REASON FOR CNV -->
                            <TextView
                                android:layout_width="45dp"
                                android:layout_height="match_parent"
                                android:text="REASON FOR CNV"
                                android:textSize="5sp"
                                android:textStyle="bold"
                                android:textColor="#000000"
                                android:gravity="center"
                                android:maxLines="2"
                                android:background="@drawable/excel_cell_border"/>
                            
                            <!-- F2: LAT-LONG FROM -->
                            <TextView
                                android:layout_width="92dp"
                                android:layout_height="match_parent"
                                android:text="LAT-LONG FROM"
                                android:textSize="7sp"
                                android:textStyle="bold"
                                android:textColor="#000000"
                                android:gravity="center"
                                android:background="@drawable/excel_cell_border"/>
                            
                            <!-- G2: LAT-LONG TO -->
                            <TextView
                                android:layout_width="95dp"
                                android:layout_height="match_parent"
                                android:text="LAT-LONG TO"
                                android:textSize="7sp"
                                android:textStyle="bold"
                                android:textColor="#000000"
                                android:gravity="center"
                                android:background="@drawable/excel_cell_border"/>
                            
                            <!-- H2: AREA -->
                            <TextView
                                android:layout_width="89dp"
                                android:layout_height="match_parent"
                                android:text="AREA"
                                android:textSize="9sp"
                                android:textStyle="bold"
                                android:textColor="#000000"
                                android:gravity="center"
                                android:background="@drawable/excel_cell_border"/>
                            
                            <!-- I2: KM -->
                            <TextView
                                android:layout_width="38dp"
                                android:layout_height="match_parent"
                                android:text="KM"
                                android:textSize="9sp"
                                android:textStyle="bold"
                                android:textColor="#000000"
                                android:gravity="center"
                                android:background="@drawable/excel_cell_border"/>
                        </LinearLayout>

                        <!-- Data Rows Container (Row 3-12) - 10 rows, height 20.25dp each -->
                        <LinearLayout
                            android:id="@+id/dataRowsContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"/>

                        <!-- Additional Rows Container (Row 13-17) - 5 rows, height 15dp each -->
                        <LinearLayout
                            android:id="@+id/additionalRowsContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"/>

                        <!-- Row 18: Blank Spacing Row -->
                        <View
                            android:layout_width="654dp"
                            android:layout_height="12dp"
                            android:background="@drawable/excel_cell_border"/>

                        <!-- Bottom Summary Table (Row 19-24) -->
                        <LinearLayout
                            android:id="@+id/summaryTableContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            
                            <!-- Row 19: Headers for Summary -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="17dp"
                                android:orientation="horizontal">
                                
                                <!-- Spacer for columns A-E -->
                                <View
                                    android:layout_width="340dp"
                                    android:layout_height="match_parent"/>
                                
                                <!-- F19: Blank -->
                                <TextView
                                    android:layout_width="92dp"
                                    android:layout_height="match_parent"
                                    android:text=""
                                    android:background="@drawable/excel_cell_border"/>
                                
                                <!-- G19: NO. OF COUNT -->
                                <TextView
                                    android:layout_width="95dp"
                                    android:layout_height="match_parent"
                                    android:text="NO. OF COUNT"
                                    android:textSize="7sp"
                                    android:textStyle="bold"
                                    android:textColor="#000000"
                                    android:gravity="center"
                                    android:background="@drawable/excel_cell_border"/>
                                
                                <!-- H19: AMOUNT -->
                                <TextView
                                    android:layout_width="127dp"
                                    android:layout_height="match_parent"
                                    android:text="AMOUNT"
                                    android:textSize="8sp"
                                    android:textStyle="bold"
                                    android:textColor="#000000"
                                    android:gravity="center"
                                    android:background="@drawable/excel_cell_border"/>
                            </LinearLayout>
                            
                            <!-- Row 20: TOTAL KM -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="25dp"
                                android:orientation="horizontal">
                                
                                <View
                                    android:layout_width="340dp"
                                    android:layout_height="match_parent"/>
                                
                                <TextView
                                    android:layout_width="92dp"
                                    android:layout_height="match_parent"
                                    android:text="TOTAL KM"
                                    android:textSize="8sp"
                                    android:textStyle="bold"
                                    android:textColor="#000000"
                                    android:gravity="center"
                                    android:background="@drawable/excel_cell_border"/>
                                
                                <EditText
                                    android:id="@+id/cellG20"
                                    android:layout_width="95dp"
                                    android:layout_height="match_parent"
                                    android:text=""
                                    android:textSize="9sp"
                                    android:textColor="#000000"
                                    android:gravity="center"
                                    android:background="@drawable/excel_cell_border"
                                    android:inputType="numberDecimal"
                                    android:singleLine="true"/>
                                
                                <EditText
                                    android:id="@+id/cellH20"
                                    android:layout_width="127dp"
                                    android:layout_height="match_parent"
                                    android:text=""
                                    android:textSize="9sp"
                                    android:textColor="#000000"
                                    android:gravity="center"
                                    android:background="@drawable/excel_cell_border"
                                    android:inputType="numberDecimal"
                                    android:singleLine="true"/>
                            </LinearLayout>
                            
                            <!-- Row 21: LUNCH -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="25dp"
                                android:orientation="horizontal">
                                
                                <View
                                    android:layout_width="340dp"
                                    android:layout_height="match_parent"/>
                                
                                <TextView
                                    android:layout_width="92dp"
                                    android:layout_height="match_parent"
                                    android:text="LUNCH"
                                    android:textSize="8sp"
                                    android:textStyle="bold"
                                    android:textColor="#000000"
                                    android:gravity="center"
                                    android:background="@drawable/excel_cell_border"/>
                                
                                <EditText
                                    android:id="@+id/cellG21"
                                    android:layout_width="95dp"
                                    android:layout_height="match_parent"
                                    android:text=""
                                    android:textSize="9sp"
                                    android:textColor="#000000"
                                    android:gravity="center"
                                    android:background="@drawable/excel_cell_border"
                                    android:inputType="number"
                                    android:singleLine="true"/>
                                
                                <EditText
                                    android:id="@+id/cellH21"
                                    android:layout_width="127dp"
                                    android:layout_height="match_parent"
                                    android:text=""
                                    android:textSize="9sp"
                                    android:textColor="#000000"
                                    android:gravity="center"
                                    android:background="@drawable/excel_cell_border"
                                    android:inputType="numberDecimal"
                                    android:singleLine="true"/>
                            </LinearLayout>
                            
                            <!-- Row 22: VISIT -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="25dp"
                                android:orientation="horizontal">
                                
                                <View
                                    android:layout_width="340dp"
                                    android:layout_height="match_parent"/>
                                
                                <TextView
                                    android:layout_width="92dp"
                                    android:layout_height="match_parent"
                                    android:text="VISIT"
                                    android:textSize="8sp"
                                    android:textStyle="bold"
                                    android:textColor="#000000"
                                    android:gravity="center"
                                    android:background="@drawable/excel_cell_border"/>
                                
                                <EditText
                                    android:id="@+id/cellG22"
                                    android:layout_width="95dp"
                                    android:layout_height="match_parent"
                                    android:text=""
                                    android:textSize="9sp"
                                    android:textColor="#000000"
                                    android:gravity="center"
                                    android:background="@drawable/excel_cell_border"
                                    android:inputType="number"
                                    android:singleLine="true"/>
                                
                                <EditText
                                    android:id="@+id/cellH22"
                                    android:layout_width="127dp"
                                    android:layout_height="match_parent"
                                    android:text=""
                                    android:textSize="9sp"
                                    android:textColor="#000000"
                                    android:gravity="center"
                                    android:background="@drawable/excel_cell_border"
                                    android:inputType="numberDecimal"
                                    android:singleLine="true"/>
                            </LinearLayout>
                            
                            <!-- Row 23: OTHER -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="26dp"
                                android:orientation="horizontal">
                                
                                <View
                                    android:layout_width="340dp"
                                    android:layout_height="match_parent"/>
                                
                                <TextView
                                    android:layout_width="92dp"
                                    android:layout_height="match_parent"
                                    android:text="OTHER"
                                    android:textSize="8sp"
                                    android:textStyle="bold"
                                    android:textColor="#000000"
                                    android:gravity="center"
                                    android:background="@drawable/excel_cell_border"/>
                                
                                <EditText
                                    android:id="@+id/cellG23"
                                    android:layout_width="95dp"
                                    android:layout_height="match_parent"
                                    android:text=""
                                    android:textSize="9sp"
                                    android:textColor="#000000"
                                    android:gravity="center"
                                    android:background="@drawable/excel_cell_border"
                                    android:inputType="number"
                                    android:singleLine="true"/>
                                
                                <EditText
                                    android:id="@+id/cellH23"
                                    android:layout_width="127dp"
                                    android:layout_height="match_parent"
                                    android:text=""
                                    android:textSize="9sp"
                                    android:textColor="#000000"
                                    android:gravity="center"
                                    android:background="@drawable/excel_cell_border"
                                    android:inputType="numberDecimal"
                                    android:singleLine="true"/>
                            </LinearLayout>
                            
                            <!-- Row 24: TOTAL AMOUNT (F24+G24 Merged) -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="15dp"
                                android:orientation="horizontal">
                                
                                <View
                                    android:layout_width="340dp"
                                    android:layout_height="match_parent"/>
                                
                                <!-- F24+G24 Merged: TOTAL AMOUNT -->
                                <TextView
                                    android:layout_width="187dp"
                                    android:layout_height="match_parent"
                                    android:text="TOTAL AMOUNT"
                                    android:textSize="8sp"
                                    android:textStyle="bold"
                                    android:textColor="#000000"
                                    android:gravity="center"
                                    android:background="@drawable/excel_cell_border"/>
                                
                                <TextView
                                    android:id="@+id/cellH24"
                                    android:layout_width="127dp"
                                    android:layout_height="match_parent"
                                    android:text=""
                                    android:textSize="9sp"
                                    android:textStyle="bold"
                                    android:textColor="#000000"
                                    android:gravity="center"
                                    android:background="@drawable/excel_cell_border"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                    
                </ScrollView>
            </HorizontalScrollView>
        </LinearLayout>
    </LinearLayout>
    
    <!-- Bottom Action Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1A237E"
        android:padding="8dp"
        android:gravity="center">
        
        <Button
            android:id="@+id/btnCopyAll"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="COPY ALL"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:background="@drawable/btn_primary_bg"
            android:layout_marginEnd="4dp"/>
        
        <Button
            android:id="@+id/btnClearTable"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="CLEAR TABLE"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:background="@drawable/btn_danger_bg"
            android:layout_marginStart="4dp"/>
    </LinearLayout>
    
</LinearLayout>
